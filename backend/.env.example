# RaceResult event configuration. All values are optional — the UI lets
# you enter an event ID at runtime, which always wins over this default.

# Default event ID used when the UI input is empty and as the fallback
# for `GET /api/...` calls that omit `event_id`.
RACERESULT_EVENT_ID=

# Only needed for the authenticated api.raceresult.com REST API.
# The public RRPublish endpoints (my.raceresult.com) do not need a key.
RACERESULT_API_KEY=

# Base URL for the RRPublish config endpoint. Override only if RaceResult
# directs you to a different region.
RACERESULT_BASE=https://my.raceresult.com
